    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
